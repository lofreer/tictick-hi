{
  "name": "tictick-hi-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "build": "pnpm run typecheck && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "lightweight-charts": "^5.0.9",
    "@lucide/vue": "^1.0.0",
    "naive-ui": "^2.43.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.22",
    "vue-i18n": "^11.1.12",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/test-utils": "^2.4.10",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.1.8"
  }
}
