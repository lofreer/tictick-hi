SYNC_MAX_RETRY_BACKOFF=5m
MARKET_INSTRUMENT_SYNC_ENABLED=true
MARKET_INSTRUMENT_SYNC_ON_START=true
MARKET_INSTRUMENT_SYNC_INTERVAL=6h
BACKTEST_POLL_INTERVAL=10s
TRADING_POLL_INTERVAL=10s
NOTIFY_POLL_INTERVAL=10s
NOTIFY_RETRY_DELAY=30s
NOTIFY_MAX_RETRY_DELAY=5m

# Optional external notification provider secrets. Keep channel targets as env references.
# Telegram target: telegram://send?chat_id=<chat-id>&token_env=TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_TOKEN=
# Feishu target: feishu://webhook?url_env=FEISHU_WEBHOOK_URL
FEISHU_WEBHOOK_URL=
# Email target: smtp://smtp.example.com:587?from=bot@example.com&to=ops@example.com&username_env=SMTP_USERNAME&password_env=SMTP_PASSWORD
SMTP_USERNAME=
SMTP_PASSWORD=
